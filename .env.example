# نسخ إلى `.env` محلياً. عند التجاهل يُستخدم الافتراضي في `src/config/apiEndpoint.js`.
#
# الإنتاج (الافتراضي في الكود):
# VITE_API_BASE_URL=https://api.altadumntest.com
#
# خيار 1 — عنوان كامل ينتهي بـ `/api`:
# VITE_API_URL=https://api.altadumntest.com/api
#
# خيار 2 — host فقط (يُضاف `/api` تلقائياً) — موصى به:
VITE_API_BASE_URL=https://api.altadumntest.com

# تطوير محلي:
# VITE_API_BASE_URL=http://localhost:5096
