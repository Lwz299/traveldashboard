# موصى به (Vercel + تطوير محلي) — طلبات عبر /api proxy بدون CORS:
VITE_API_URL=/api
VITE_API_ASSET_ORIGIN=https://api.altadumntest.com

# اختياري: هدف الـ proxy في vite.config (افتراضي api.altadumntest.com)
# VITE_API_PROXY_TARGET=https://api.altadumntest.com

# اتصال مباشر (يتطلب CORS من الباكند — لا يُنصح على Vercel):
# VITE_API_BASE_URL=https://api.altadumntest.com
# VITE_API_URL=https://api.altadumntest.com/api

# تطوير محلي على localhost:5096:
# VITE_API_PROXY_TARGET=http://localhost:5096
# VITE_API_ASSET_ORIGIN=http://localhost:5096
